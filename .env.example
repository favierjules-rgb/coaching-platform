# Copier ce fichier vers .env.local et renseigner les valeurs réelles.
# .env.local est ignoré par git (voir .gitignore) — jamais commiter de vraie
# clé/secret. Ce fichier .env.example ne contient que des noms de variables,
# aucune valeur sensible.

# ─── Supabase ───
# Project Settings > API dans le dashboard Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — secrète, serveur uniquement (lib/supabase/admin.ts). Requise
# pour le webhook Stripe (lib/stripe/webhook-handlers.ts contourne RLS après
# vérification de signature).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (chantier "supabase-stripe-payments-subscriptions") ───
# Developers > API keys dans le dashboard Stripe.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Developers > Webhooks > signing secret (voir docs/supabase-stripe-payments-subscriptions-model.md
# pour la configuration de l'endpoint /api/stripe/webhook).
STRIPE_WEBHOOK_SECRET=

# Garde test/live des webhooks (Lot W1 — juillet 2026). NE CONTIENT AUCUN
# SECRET : uniquement "true" ou "false".
#
# Avant tout traitement, la route /api/stripe/webhook compare
# `event.livemode` à cette valeur. En cas de différence — ou si la variable
# est absente — l'évènement est rejeté (HTTP 403) SANS exécuter le handler
# et SANS écrire la moindre ligne dans `billing_events` : un évènement du
# compte de test ne peut donc jamais polluer un environnement live, ni
# l'inverse.
#
# Volontairement NON dérivée de NODE_ENV : une préproduction tourne en
# NODE_ENV=production tout en devant rester en mode test, et un
# NODE_ENV=development pointant par erreur sur des clés live doit être
# bloqué. Seule une variable explicite exprime l'intention réelle.
#
#   développement / préproduction : false
#   production réelle             : true
STRIPE_EXPECTED_LIVEMODE=false

# Price ID Stripe des 3 anciennes formules de coaching (Product catalog >
# Prices dans le dashboard Stripe) — repli ADMIN UNIQUEMENT, voir
# lib/stripe/plans.ts / lib/stripe/plans-server.ts. La table Supabase
# `subscription_templates` (gérée depuis /admin/abonnements, aucune
# variable d'environnement à modifier pour ajouter/changer une formule) est
# la seule source utilisée pour un élève : un élève ne peut jamais payer une
# formule issue de ces 3 variables, uniquement le modèle qui lui a été
# attribué par le coach (student_profiles.assigned_subscription_template_id).
# Ces 3 variables ne sont lues que si un admin/coach choisit explicitement
# une ancienne formule .env depuis la fiche élève ou /admin/paiements, en
# l'absence de tout modèle actif.
STRIPE_PRICE_COACHING_BASIC=
STRIPE_PRICE_COACHING_PREMIUM=
STRIPE_PRICE_COACHING_DISTANCIEL=

# URL publique du site, utilisée pour les success_url/cancel_url Stripe
# Checkout et le return_url du Customer Portal (ex: http://localhost:3000
# en local, https://votredomaine.fr en production), ainsi que pour les liens
# cliquables dans les emails transactionnels ci-dessous.
NEXT_PUBLIC_APP_URL=

# ─── Resend (chantier "supabase-resend-transactional-emails") ───
# https://resend.com/api-keys — clé secrète, serveur uniquement
# (lib/email/resend.ts). Absente ou EMAILS_ENABLED=false : aucun email n'est
# réellement envoyé, journalisé "skipped" dans `email_logs`, l'application
# ne plante jamais pour autant (voir docs/resend-transactional-emails.md).
RESEND_API_KEY=
# Adresse d'expédition — doit appartenir à un domaine vérifié (SPF/DKIM/DMARC)
# dans Resend, voir docs/resend-transactional-emails.md. Ex : "SETH Préparation Physique <contact@votredomaine.fr>".
RESEND_FROM_EMAIL=
# Adresse "Répondre à" affichée aux destinataires (peut différer de
# RESEND_FROM_EMAIL, ex : une boîte suivie par le coach).
RESEND_REPLY_TO=
# Coupe-circuit global : "false" désactive tout envoi réel même si
# RESEND_API_KEY est configurée (utile en préproduction/staging) — les
# emails sont alors journalisés en statut "skipped". Par défaut "true" si
# absente.
EMAILS_ENABLED=true

# Secret partagé pour authentifier les appels du cron des rappels de
# rendez-vous (app/api/cron/appointment-reminders/route.ts, voir
# docs/resend-transactional-emails.md) — Vercel Cron l'envoie automatiquement
# en en-tête `Authorization: Bearer <valeur>` si configuré dans vercel.json.
CRON_SECRET=

# Newsletter (Brevo) - separe des emails transactionnels Resend
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_WEBHOOK_SECRET=
NEWSLETTER_ENABLED=
NEXT_PUBLIC_APP_URL=
