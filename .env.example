# Copier ce fichier vers .env.local et renseigner les valeurs réelles.
# .env.local est ignoré par git (voir .gitignore) — jamais commiter de vraie
# clé/secret. Ce fichier .env.example ne contient que des noms de variables,
# aucune valeur sensible.

# ─── Supabase ───
# Project Settings > API dans le dashboard Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — secrète, serveur uniquement (lib/supabase/admin.ts). Requise
# pour le webhook Stripe (lib/stripe/webhook-handlers.ts contourne RLS après
# vérification de signature).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (chantier "supabase-stripe-payments-subscriptions") ───
# Developers > API keys dans le dashboard Stripe.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Developers > Webhooks > signing secret (voir docs/supabase-stripe-payments-subscriptions-model.md
# pour la configuration de l'endpoint /api/stripe/webhook).
STRIPE_WEBHOOK_SECRET=

# Price ID Stripe des 3 formules de coaching (Product catalog > Prices dans
# le dashboard Stripe) — repli TEMPORAIRE uniquement, voir
# lib/stripe/plans.ts / lib/stripe/plans-server.ts. Depuis le chantier
# "supabase-subscription-templates", la source prioritaire des formules
# proposées est la table Supabase `subscription_templates` (gérée depuis
# /admin/abonnements, aucune variable d'environnement à modifier pour
# ajouter/changer une formule) — ces 3 variables ne servent plus que si
# aucun modèle actif n'existe encore en base.
STRIPE_PRICE_COACHING_BASIC=
STRIPE_PRICE_COACHING_PREMIUM=
STRIPE_PRICE_COACHING_DISTANCIEL=

# URL publique du site, utilisée pour les success_url/cancel_url Stripe
# Checkout et le return_url du Customer Portal (ex: http://localhost:3000
# en local, https://votredomaine.fr en production).
NEXT_PUBLIC_APP_URL=
