# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# outillage local skills (npx skills) — cache d'installation, pas du code projet
.agents/
agent/
skills-lock.json

# débris de build .next issus d'un bug d'environnement (voir rapport Lot 1) —
# à supprimer manuellement depuis le Finder/Terminal, `rm` échoue dessus ici
.next-broken-*/
.next-old-*/

# Sources visuelles locales — non versionnées
brand/images/
brand/transformations/approved/
# Fichiers macOS
.DS_Store
**/.DS_Store
